<tt xmlns="http://www.w3.org/ns/ttml" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:amll="http://www.example.com/ns/amll" itunes:timing="Word" xml:lang="zh-Hans"><head><metadata><ttm:agent type="person" xml:id="v1"/><amll:meta key="musicName" value="一颗方糖悬滞的时间 (feat. 阿兰·达瓦卓玛)"/><amll:meta key="musicName" value="一颗方糖悬滞的时间"/><amll:meta key="musicName" value="《绝区零》朱鸢EP"/><amll:meta key="musicName" value="《绝区零》朱鸢角色曲"/><amll:meta key="musicName" value="一顆方糖懸滯的時間 (feat. 阿蘭·達瓦卓瑪)"/><amll:meta key="musicName" value="一顆方糖懸滯的時間"/><amll:meta key="musicName" value="角砂糖が沈むまで (feat. 阿兰·达瓦卓玛)"/><amll:meta key="musicName" value="角砂糖が沈むまで"/><amll:meta key="musicName" value="각설탕 하나가 떠 있는 시간 (feat. 阿兰·达瓦卓玛)"/><amll:meta key="musicName" value="각설탕 하나가 떠 있는 시간"/><amll:meta key="musicName" value="As the sugar cube floats, fleeting in time (feat. 阿兰·达瓦卓玛)"/><amll:meta key="musicName" value="As the sugar cube floats, fleeting in time"/><amll:meta key="artists" value="HOYO-MiX"/><amll:meta key="artists" value="三Z-STUDIO"/><amll:meta key="artists" value="Sān-Z"/><amll:meta key="artists" value="阿兰"/><amll:meta key="artists" value="阿兰·达瓦卓玛"/><amll:meta key="artists" value="ALAN"/><amll:meta key="artists" value="Alan Dawa Dolma"/><amll:meta key="artists" value="アラン·ダワジュオマ"/><amll:meta key="album" value="绝区零-一颗方糖悬滞的时间"/><amll:meta key="album" value="一颗方糖悬滞的时间 - Single"/><amll:meta key="album" value="一顆方糖懸滯的時間 - Single"/><amll:meta key="album" value="一顆方糖懸滯的時間"/><amll:meta key="album" value="角砂糖が沈むまで (feat. 阿兰·达瓦卓玛) - Single"/><amll:meta key="album" value="角砂糖が沈むまで"/><amll:meta key="album" value="각설탕 하나가 떠 있는 시간 - Single"/><amll:meta key="album" value="각설탕 하나가 떠 있는 시간"/><amll:meta key="album" value="As the sugar cube floats, fleeting in time - Single"/><amll:meta key="album" value="As the sugar cube floats, fleeting in time"/><amll:meta key="isrc" value="DGA072492989"/><amll:meta key="isrc" value="DGA082412140"/><amll:meta key="isrc" value="DGA082421563"/><amll:meta key="isrc" value="DGA082410574"/><amll:meta key="isrc" value="DGA082410599"/><amll:meta key="ncmMusicId" value="2612750275"/><amll:meta key="qqMusicId" value="002TFWxI3SlNwx"/><amll:meta key="qqMusicId" value="503998396"/><amll:meta key="spotifyId" value="66izH92bA85wuJFFgJ0HRy"/><amll:meta key="spotifyId" value="4o9pXElZZFjQBlhSWTNBQC"/><amll:meta key="spotifyId" value="2excpOrcz3wOViAA3cBMpU"/><amll:meta key="spotifyId" value="52GlYDlUFY2v9NfA1kGyEQ"/><amll:meta key="appleMusicId" value="1758391074"/><amll:meta key="appleMusicId" value="1758774905"/><amll:meta key="appleMusicId" value="1759153566"/><amll:meta key="appleMusicId" value="1758774295"/><amll:meta key="appleMusicId" value="1758784690"/><amll:meta key="ttmlAuthorGithub" value="68000793"/><amll:meta key="ttmlAuthorGithub" value="50747104"/><amll:meta key="ttmlAuthorGithubLogin" value="ranhengzhang"/><amll:meta key="ttmlAuthorGithubLogin" value="Xionghaizi001"/><amll:meta key="Arranger" value="杨武韬"/><amll:meta key="Composer" value="杨武韬"/><amll:meta key="Drums" value="眭逸凡"/><amll:meta key="Editing Engineer" value="徐威"/><amll:meta key="Guitar" value="雷十一"/><amll:meta key="Lyrics" value="熊子"/><amll:meta key="Mixing Engineer" value="黄钦胜"/><amll:meta key="Producer" value="杨武韬"/><amll:meta key="Recording Engineer" value="袁雄宇"/><amll:meta key="Vocals" value="阿兰"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation xml:lang="de"><text for="L1">erblühen die Frühlingsblumen gerade außerhalb,</text><text for="L2">und ein Spatz sitzt sanft auf einem Zweig.</text><text for="L3">Eine Melodie, zum ersten Mal wahrgenommen,</text><text for="L4">geht mir unerwartet zu Herzen.</text><text for="L5">Das Räucherstäbchen verbrennt.</text><text for="L6">Ich lasse meine Haare herunter,</text><text for="L7">und bestaune das unbekannte weiche Licht,</text><text for="L8">das an einem Morgen glatt wie Papier erstrahlt.</text><text for="L9">Eine Schafherde jagt hinter den Schatten der Wolken hinterher.</text><text for="L10">Sag irgendetwas, um mich in den Schlaf zu wiegen.<span ttm:role="x-bg">(in den Schlaf zu wiegen.)</span></text><text for="L11">Ein hohles Weltbild, von mir allein erfasst,</text><text for="L12">und sodann in die Tat umgesetzt.</text><text for="L13">Es schwellt an,</text><text for="L14">ein Sonntag für mich alleine,</text><text for="L15">um mich leise zu besinnen, langsam zu erinnern.</text><text for="L16">So wie der Zuckerwürfel treibt, vergänglich im Fluss der Zeit.</text><text for="L17">Eine Tasse voll Erholung, zwei Gefühle der Sorge.</text><text for="L18">Eine Zeit, jenseits der Zeit.</text><text for="L19">Ein leiser, leerer Raum.</text><text for="L20">Eintausend und eine Unentschlossenheit.</text><text for="L21">Ich will nichts verpassen, doch kann mich nicht voll und ganz darauf einzulassen.</text><text for="L22">Zeit, den Kopf in den Sand zu stecken und die Welt zu vergessen.<span ttm:role="x-bg">(ha~ die Welt zu vergessen.)</span></text><text for="L23">Gierig zu sein, einfach zu sein,</text><text for="L24">bis ein Neumond in die Tiefen der Tasse sinkt,</text><text for="L25">und noch immer nach etwas Neuem sucht.</text><text for="L26">Ein Sonntag für mich alleine,</text><text for="L27">macht sich heimlich davon, hinter den Horizont,</text><text for="L28">wie eine lange Nacht ohne Namen.</text><text for="L29">Geht es dir gut? Meine Gedanken flimmern.<span ttm:role="x-bg">(Meine Gedanken flimmern.)</span></text><text for="L30">Eine Zeit, jenseits der Zeit.</text><text for="L31">Ein leiser, leerer Raum.</text><text for="L32">So wie der Zuckerwürfel treibt, vergänglich im Fluss der Zeit.<span ttm:role="x-bg">(vergänglich im Fluss der Zeit.)</span></text><text for="L33">so schnell geschmolzen und zurückgekehrt ins Morgen, so voller Unwissenheit.</text></translation><translation xml:lang="en"><text for="L1">The springtime blooming just outside</text><text for="L2">A sparrow perched on a branch</text><text for="L3">A melody heard for the first time</text><text for="L4">Plucks at my heartstrings unforeseen</text><text for="L5">Incense burning</text><text for="L6">I let down my hair</text><text for="L7">Gazing at the unfamiliar soft light</text><text for="L8">That shines upon on a morning paper-flat</text><text for="L9">A flock of sheep chasing shadows cast by clouds</text><text for="L10">Say anything to lull me to sleep<span ttm:role="x-bg">(lull me to sleep)</span></text><text for="L11">An empty philosophy realized alone</text><text for="L12">Then put into practice</text><text for="L13">Slowly rising</text><text for="L14">A Sunday, all on my own</text><text for="L15">Gently reflecting, slowly recollecting</text><text for="L16">As the sugar cube floats, fleeting in time</text><text for="L17">One cup of respite, two feelings of fret</text><text for="L18">A time, beyond time</text><text for="L19">A gentle, empty room</text><text for="L20">A thousand and one indecisions</text><text for="L21">Unwilling to miss out, yet unable to fully commit</text><text for="L22">Time to bury my head in the sand and forget the world<span ttm:role="x-bg">(ha~ forget the world)</span></text><text for="L23">To be greedy, to be simple</text><text for="L24">Until a new moon sinks to the bottom of the cup</text><text for="L25">Still looking for that something new</text><text for="L26">A Sunday, all on my own</text><text for="L27">Slips beyond, the horizon</text><text for="L28">Like the nameless long night</text><text for="L29">Are you alright? My thoughts flicker<span ttm:role="x-bg">(My thoughts flicker)</span></text><text for="L30">A time, beyond time</text><text for="L31">A gentle, empty room</text><text for="L32">As the sugar cube floats, fleeting in time<span ttm:role="x-bg">(fleeting in time)</span></text><text for="L33">Melted away, and back to tomorrow — so full of unknowns</text></translation><translation xml:lang="es"><text for="L1">El aire primaveral sopla fuera de la habitación</text><text for="L2">Sobre la rama descansa un gorrión</text><text for="L3">Se escucha por primera vez una canción</text><text for="L4">Siento caricias en el corazón</text><text for="L5">Una varilla de incienso que arde con pasión</text><text for="L6">El cabello suelto sin restricción</text><text for="L7">La luz tenue y desconocida ilumina mi visión</text><text for="L8">Un amanecer despejado</text><text for="L9">Un rebaño de ovejas que persigue las nubes</text><text for="L10">Palabras que llevan a un mundo de ilusiones<span ttm:role="x-bg">(que llevan a un mundo de ilusiones)</span></text><text for="L11">En la filosofía vacía no hay colaboraciones</text><text for="L12">Practicar</text><text for="L13">Elevarse hasta ciertos niveles</text><text for="L14">Un domingo solitario</text><text for="L15">Con suavidad y dilación</text><text for="L16">El tiempo fluye para este terrón</text><text for="L17">Una taza de tranquilidad, dos de preocupación</text><text for="L18">Más allá de la hora en el reloj</text><text for="L19">Una sala vacía con un ambiente acogedor</text><text for="L20">Una mente plagada de indecisión</text><text for="L21">Ni la ausencia ni el compromiso son una opción</text><text for="L22">Tal vez debería esconderme y el mundo olvidar<span ttm:role="x-bg">(ha~ el mundo olvidar)</span></text><text for="L23">Por la codicia y la ingenuidad dejarme llevar</text><text for="L24">Hasta que la luna se hunda en el fondo del vaso</text><text for="L25">U ocurra algo que resulte novedoso</text><text for="L26">Un domingo solitario</text><text for="L27">se desliza hacia el horizonte con decisión</text><text for="L28">Como una noche sin nombre y sin conclusión</text><text for="L29">¿Estás bien? Mis pensamientos han comenzado su disipación<span ttm:role="x-bg">(Mis pensamientos han comenzado su disipación)</span></text><text for="L30">Más allá de la hora en el reloj</text><text for="L31">Una sala vacía con un ambiente acogedor</text><text for="L32">El tiempo fluye para este terrón<span ttm:role="x-bg">(el tiempo fluye para este terrón)</span></text><text for="L33">Una vez derretido, nuestro futuro será una interrogación</text></translation><translation xml:lang="fr"><text for="L1">Le printemps fleurit par la fenêtre</text><text for="L2">Un moineau perché sur une branche</text><text for="L3">Une mélodie perçue pour la première fois</text><text for="L4">A soudain effleuré mon cœur</text><text for="L5">L&apos;encens brûle</text><text for="L6">J&apos;ai détaché mes cheveux</text><text for="L7">J&apos;observe la lumière tamisée qui m&apos;est inconnue</text><text for="L8">Qui illumine un matin aussi plat que du papier</text><text for="L9">Des moutons chassent l&apos;ombre des nuages</text><text for="L10">Les mots m&apos;emportent vers les bras Morphée<span ttm:role="x-bg">(vers les bras Morphée)</span></text><text for="L11">Une philosophie vide réalisée par soi-même</text><text for="L12">Puis pratiquée</text><text for="L13">Qui s&apos;élève lentement</text><text for="L14">Un dimanche, solitaire</text><text for="L15">Réfléchir doucement, se souvenir lentement</text><text for="L16">Alors que le carré de sucre flotte, fugace dans le temps</text><text for="L17">Un verre de répit, deux soucis</text><text for="L18">Un temps, au-delà du temps</text><text for="L19">Une chambre vide, pleine de douceur</text><text for="L20">Mille et une haltes</text><text for="L21">Refuser l&apos;absence, mais ne pas savoir s&apos;engager</text><text for="L22">Tel un rocher, peut-être est-il temps d&apos;oublier le monde<span ttm:role="x-bg">(ha~ oublier le monde)</span></text><text for="L23">D&apos;être gourmand, d&apos;être simple</text><text for="L24">Jusqu&apos;à ce qu&apos;une nouvelle lune sombre au fond de la tasse</text><text for="L25">Toujours à la recherche de ce qui est nouveau</text><text for="L26">Un dimanche, solitaire</text><text for="L27">Qui se dérobe, à l&apos;horizon</text><text for="L28">Une longue nuit indescriptible</text><text for="L29">Tu vas bien ? Mes pensées vacillent<span ttm:role="x-bg">(Mes pensées vacillent)</span></text><text for="L30">Un temps, au-delà du temps</text><text for="L31">Une chambre vide, pleine de douceur</text><text for="L32">Alors que le carré de sucre flotte, fugace dans le temps<span ttm:role="x-bg">(fugace dans le temps)</span></text><text for="L33">Il a fondu, vers un nouveau lendemain, vers l&apos;inconnu</text></translation><translation xml:lang="id"><text for="L1">Musim semi di luar jendela</text><text for="L2">Burung pipit bertengger di dahan</text><text for="L3">Melodi yang kudengar untuk pertama kalinya</text><text for="L4">Tanpa sadar telah menyentuh hati</text><text for="L5">Menyalakan pewangi</text><text for="L6">Aku menggerai rambutku</text><text for="L7">Melihat cahaya lembut yang tidak familier</text><text for="L8">Menyinari pagi yang datar bagai kertas</text><text for="L9">Sekawanan domba mengejar bayangan awan</text><text for="L10">Bisikkan sesuatu dan antar aku ke alam mimpi<span ttm:role="x-bg">(antar aku ke alam mimpi)</span></text><text for="L11">Filosofi kosong yang disadari sendiri</text><text for="L12">Lalu diterapkan dalam praktik</text><text for="L13">Perlahan mengambang</text><text for="L14">Hari minggu, sendirian</text><text for="L15">Dengan lembut merenung, dengan perlahan mengenang</text><text for="L16">Gula batu mengapung, larut dalam waktu</text><text for="L17">Secangkir rasa ketenangan, dua rasa kegelisahan</text><text for="L18">Waktu, di luar waktu</text><text for="L19">Ketenangan, di ruang hampa</text><text for="L20">Seribu satu keraguan</text><text for="L21">Tak ingin melewatinya, namun tak dapat berjanji</text><text for="L22">Mungkin saatnya mengubur kepalaku di pasir dan melupakan dunia<span ttm:role="x-bg">(ha~ melupakan dunia)</span></text><text for="L23">Menjadi lebih serakah, berpikir lebih sederhana</text><text for="L24">Hingga bulan baru tenggelam ke dasar gelas</text><text for="L25">Kita masih menantikan sesuatu yang baru</text><text for="L26">Hari minggu, sendirian</text><text for="L27">Melayang pergi, ke cakrawala</text><text for="L28">Seperti malam yang tak kunjung akhir</text><text for="L29">Apa kamu baik-baik saja? Pikiran pun datang dan pergi<span ttm:role="x-bg">(Pikiran pun datang dan pergi)</span></text><text for="L30">Waktu, di luar waktu</text><text for="L31">Ketenangan, di ruang hampa</text><text for="L32">Gula batu mengapung, larut dalam waktu<span ttm:role="x-bg">(larut dalam waktu)</span></text><text for="L33">Meleleh, dan kembali ke esok hari yang penuh kejutan</text></translation><translation xml:lang="ja"><text for="L1">窓の外は春</text><text for="L2">枝にすずめがとまり</text><text for="L3">聞き覚えのない旋律が</text><text for="L4">ふいに心を撫でる</text><text for="L5">お香に火をつけ</text><text for="L6">きつく結んだ髪をほどく</text><text for="L7">見知らぬ光が柔らかく</text><text for="L8">昼を照らす まっ平な紙のよう</text><text for="L9">雲の影を追う羊たち</text><text for="L10">言葉の微睡むに任せ<span ttm:role="x-bg">(微睡むに任せ)</span></text><text for="L11">余白のある哲学にひとり頷き</text><text for="L12">反芻しては</text><text for="L13">浮かぶ</text><text for="L14">一人だけの 日曜日</text><text for="L15">そっと振り返り 触れる</text><text for="L16">角砂糖が沈むまで</text><text for="L17">一杯のお暇 気がかりは二つ</text><text for="L18">時間の外に 時間</text><text for="L19">空っぽの部屋は 優しくて</text><text for="L20">千と一の足踏み</text><text for="L21">失いたくないけど 追い求める覚悟もなくて</text><text for="L22">石ころみたいに世界を忘れて<span ttm:role="x-bg">(ha~ 世界を忘れて)</span></text><text for="L23">もっと欲張りで 素直になれたら</text><text for="L24">月がまた一粒 コップの底に沈むまで</text><text for="L25">まだ新しい何かを待ってる</text><text for="L26">一人だけの 日曜日</text><text for="L27">地平線に 溶ける</text><text for="L28">言い表せないような長い夜</text><text for="L29">お元気ですか 浮かんでは消える<span ttm:role="x-bg">(浮かんでは消える)</span></text><text for="L30">時間の外に 時間</text><text for="L31">空っぽの部屋は 優しくて</text><text for="L32">角砂糖が沈んだら<span ttm:role="x-bg">(角砂糖が沈むまで)</span></text><text for="L33">ほらまた わからないことだらけの明日</text></translation><translation xml:lang="ko"><text for="L1">창밖의 봄날</text><text for="L2">가지에 머무는 참새</text><text for="L3">처음 느껴본 선율이</text><text for="L4">무심결에 마음을 스쳐</text><text for="L5">향을 피우고</text><text for="L6">꽉 묶었던 머리를 풀어</text><text for="L7">낯선 부드러운 빛을 바라봐</text><text for="L8">종이처럼 평평한 낮을 비춰</text><text for="L9">구름 그림자를 쫓는 양 떼</text><text for="L10">말소리조차 천천히 잠에 들어<span ttm:role="x-bg">(천천히 잠에 들어)</span></text><text for="L11">홀로 깨닫는 여백의 철학</text><text for="L12">홀로 연습해</text><text for="L13">조금씩 떠올라</text><text for="L14">혼자 보내는 일요일</text><text for="L15">살며시 모아 천천히 매만져</text><text for="L16">각설탕 하나가 떠 있는 시간</text><text for="L17">한 잔의 여유 두 가지 걱정</text><text for="L18">시간 외의 시간</text><text for="L19">따뜻한 빈방</text><text for="L20">무수한 휴식</text><text for="L21">빠지고 싶지도 완전히 미련을 둘 수도 없어</text><text for="L22">바위처럼 세상을 잊고<span ttm:role="x-bg">(ha~ 세상을 잊고)</span></text><text for="L23">조금 더 욕심을 내 조금 더 단순하게</text><text for="L24">또 다른 달이 잔의 바닥에 가라앉을 때까지 기다려</text><text for="L25">또 새로운 무언갈 기대해</text><text for="L26">혼자 보내는 일요일</text><text for="L27">지평선을 따라 미끄러져 가</text><text for="L28">이름 모를 기나긴 밤</text><text for="L29">넌 잘 지낼까 생각은 또 사라져가<span ttm:role="x-bg">(생각은 또 사라져가)</span></text><text for="L30">시간 외의 시간</text><text for="L31">따뜻한 빈방</text><text for="L32">각설탕 하나가 떠 있는 시간<span ttm:role="x-bg">(각설탕 하나가 떠 있는 시간)</span></text><text for="L33">녹아버리면 다시 알 수 없는 내일이 찾아와</text></translation><translation xml:lang="pt"><text for="L1">A primavera florescendo do lado de fora</text><text for="L2">Um pardal pousado suavemente em um galho</text><text for="L3">Uma melodia que se escuta pela primeira vez</text><text for="L4">Atrai meu coração inesperadamente</text><text for="L5">O incenso queimando</text><text for="L6">Soltei meu cabelo</text><text for="L7">Contemplando a luz suave e desconhecida</text><text for="L8">Que brilha sobre um jornal matinal</text><text for="L9">Um rebanho de ovelhas perseguindo as sombras projetadas pelas nuvens</text><text for="L10">Diga qualquer coisa para me fazer dormir<span ttm:role="x-bg">(para me fazer dormir)</span></text><text for="L11">Uma filosofia vazia realizada sozinha</text><text for="L12">E coloque em prática</text><text for="L13">Subindo lentamente</text><text for="L14">Um domingo, completamente sozinho</text><text for="L15">Refletindo suavemente, lembrando-se lentamente</text><text for="L16">Enquanto o cubo de açúcar flutua no tempo</text><text for="L17">Uma xícara de descanso, com dois sentimentos de preocupação</text><text for="L18">Um tempo, além do tempo</text><text for="L19">Uma sala gentil e vazia</text><text for="L20">Mil e uma indecisões</text><text for="L21">Não quer perder nada, mas não consegue se comprometer totalmente</text><text for="L22">É hora de enterrar minha cabeça na areia e esquecer o mundo<span ttm:role="x-bg">(ha~ esquecer o mundo)</span></text><text for="L23">Ser ganancioso, e ser simples</text><text for="L24">Até que uma lua nova afunde no fundo da xícara</text><text for="L25">Ainda procurando por algo novo</text><text for="L26">Um domingo, completamente sozinho</text><text for="L27">Deslize para além do horizonte</text><text for="L28">Como a longa noite sem nome</text><text for="L29">Você está bem? Meus pensamentos oscilam<span ttm:role="x-bg">(Meus pensamentos oscilam)</span></text><text for="L30">Um tempo, além do tempo</text><text for="L31">Uma sala gentil e vazia</text><text for="L32">Enquanto o cubo de açúcar flutua no tempo<span ttm:role="x-bg">(flutua no tempo)</span></text><text for="L33">Derretido e de volta ao amanhã - tão cheio de desconhecidos</text></translation><translation xml:lang="ru"><text for="L1">За окном расцветает весна,</text><text for="L2">воробьи присели на ветку.</text><text for="L3">Эту мелодию слышу впервые,</text><text for="L4">она вдруг трогает меня за сердце.</text><text for="L5">Зажгу свечу,</text><text for="L6">распущу свои косы.</text><text for="L7">Смотрю я на свет, что так мягко блестит.</text><text for="L8">Освещается утро, словно белый лист.</text><text for="L9">Барашки в небе гонят облака.</text><text for="L10">Я усну под твои слова.<span ttm:role="x-bg">(под твои слова.)</span></text><text for="L11">Философию пустоты познаёшь лишь в одиночестве.</text><text for="L12">Познаёшь и практикуешь.</text><text for="L13">Я встречаю новый день.</text><text for="L14">Воскресенье наедине с собой.</text><text for="L15">К воспоминаньям возвращаюсь.</text><text for="L16">Время тает, как кубик сахара.</text><text for="L17">И в это мгновение спокойствия в голове лишь две мысли.</text><text for="L18">Время вне времени.</text><text for="L19">Спокойная пустая комната.</text><text for="L20">Тысяча и одна попытка перевести дух.</text><text for="L21">Боюсь упустить, но не могу себя заставить.</text><text for="L22">Может, просто спрятать голову в песок?<span ttm:role="x-bg">(ha~ спрятать голову в песок?)</span></text><text for="L23">Нужно хотеть большего, но быть проще.</text><text for="L24">И пока новая луна не отразится в моей чашке,</text><text for="L25">я буду ждать чего-то нового.</text><text for="L26">Воскресенье наедине с собой.</text><text for="L27">Ускользает за горизонт,</text><text for="L28">словно безымянная долгая ночь.</text><text for="L29">«Как ты?» — внезапный вопрос, словно вспышка.<span ttm:role="x-bg">(словно вспышка.)</span></text><text for="L30">Время вне времени.</text><text for="L31">Спокойная пустая комната.</text><text for="L32">Время тает, как кубик сахара.<span ttm:role="x-bg">(как кубик сахара.)</span></text><text for="L33">Когда он растает, снова наступит завтрашний день, полный неизведанного.</text></translation><translation xml:lang="th"><text for="L1">ฤดูใบไม้ผลิกำลังเบ่งบานอยู่ด้านนอก</text><text for="L2">นกกระจอกเกาะอยู่บนกิ่งไม้</text><text for="L3">ท่วงทำนองที่ได้ยินเป็นครั้งแรก</text><text for="L4">ดึงดูดใจฉันอย่างไม่คาดฝัน</text><text for="L5">จุดธูปหอม</text><text for="L6">ฉันปล่อยผมลง</text><text for="L7">จ้องมองแสงอันนุ่มนวลที่ไม่แปลกตา</text><text for="L8">ส่องสว่างยามเช้าที่ราบเรียบราวกับกระดาษ</text><text for="L9">ฝูงแกะที่วิ่งไล่ตามเงาเมฆ</text><text for="L10">พูดอะไรก็ได้เพื่อกล่อมฉันให้นอนหลับ<span ttm:role="x-bg">(เพื่อกล่อมฉันให้นอนหลับ)</span></text><text for="L11">ปรัชญาที่ว่างเปล่าต้องตระหนักรู้ด้วยตัวเอง</text><text for="L12">แล้วนำไปปฏิบัติ</text><text for="L13">ลอยขึ้นมาช้าๆ</text><text for="L14">วันอาทิตย์ ฉันอยู่คนเดียวได้</text><text for="L15">ค่อยๆ ไตร่ตรอง ค่อยๆ จดจำ</text><text for="L16">ขณะที่ก้อนน้ำตาลลอยละล่อง ก็ละลายไปตามกาลเวลา</text><text for="L17">ในช่วงเวลาแห่งความสงบ มีสองความคิดในหัวของฉัน</text><text for="L18">เวลาที่อยู่เหนือกาลเวลา</text><text for="L19">ห้องอันอ่อนโยนและว่างเปล่า</text><text for="L20">ความลังเลนับพันครั้ง</text><text for="L21">ไม่อยากพลาด แต่ยังไม่สามารถทำได้เต็มที่</text><text for="L22">ถึงเวลาหลีกหนีทุกสิ่ง และลืมโลกนี้<span ttm:role="x-bg">(ha~ และลืมโลกนี้)</span></text><text for="L23">จงเป็นคนโลภ และเป็นคนไร้เดียงสา</text><text for="L24">จนกระทั่งพระจันทร์ดวงใหม่จมลงสู่ก้นแก้ว</text><text for="L25">ยังคงมองหาสิ่งใหม่ๆ</text><text for="L26">วันอาทิตย์ ฉันอยู่คนเดียวได้</text><text for="L27">ล่องลอยออกไป สู่เส้นขอบฟ้า</text><text for="L28">เหมือนค่ำคืนอันยาวนานไร้ชื่อ</text><text for="L29">คุณสบายดีมั้ย? ความคิดของฉันกำลังสั่นคลอน<span ttm:role="x-bg">(ความคิดของฉันกำลังสั่นคลอน)</span></text><text for="L30">เวลาที่อยู่เหนือกาลเวลา</text><text for="L31">ห้องอันอ่อนโยนและว่างเปล่า</text><text for="L32">ขณะที่ก้อนน้ำตาลลอยละล่อง ก็ละลายไปตามกาลเวลา<span ttm:role="x-bg">(ขณะที่ก้อนน้ำตาลลอยละล่อง)</span></text><text for="L33">ละลายแล้ว กลับไปสู่วันพรุ่งนี้ที่เต็มไปด้วยสิ่งที่ไม่รู้จัก</text></translation><translation xml:lang="vi"><text for="L1">Mùa xuân nở rộ ngoài ô cửa</text><text for="L2">Chim sẻ đậu trên cành</text><text for="L3">Giai điệu lần đầu tiên được nghe</text><text for="L4">Vô tình chạm đến trái tim</text><text for="L5">Đốt ngọn nến thơm</text><text for="L6">Buông xõa mái tóc</text><text for="L7">Nhìn ánh sáng dịu nhẹ xa lạ</text><text for="L8">Soi sáng buổi sáng bình yên</text><text for="L9">Đàn cừu đuổi theo bóng mây</text><text for="L10">Chầm chậm bước vào giấc ngủ<span ttm:role="x-bg">(bước vào giấc ngủ)</span></text><text for="L11">Tự lĩnh hội triết học</text><text for="L12">Luyện tập</text><text for="L13">Dần quen với</text><text for="L14">Ngày chủ nhật, một mình</text><text for="L15">Nhẹ nhàng ghép lại, chầm chậm hòa trộn</text><text for="L16">Viên đường chậm rãi hòa tan trong dòng thời gian</text><text for="L17">Một ly nhàn rỗi, hai nỗi nhớ mong</text><text for="L18">Khoảng thời gian, ở ngoài thời gian</text><text for="L19">Căn phòng trống, dịu dàng</text><text for="L20">Một ngàn lẻ một kiểu nghỉ ngơi</text><text for="L21">Không muốn vắng mặt, nhưng lại không thể hoàn toàn quyến luyến</text><text for="L22">Có lẽ phải học cách quên đi thế giới như viên đá<span ttm:role="x-bg">(ha~ quên đi thế giới)</span></text><text for="L23">Tham lam một chút, đơn giản một chút</text><text for="L24">Đợi ánh trăng chìm trong ly nước</text><text for="L25">Cũng vẫn mong chờ điều gì đó mới mẻ</text><text for="L26">Ngày chủ nhật, một mình</text><text for="L27">Trượt vào, đường chân trời</text><text for="L28">Đêm dài yên tĩnh</text><text for="L29">Vẫn khỏe chứ? Suy nghĩ lướt qua<span ttm:role="x-bg">(Suy nghĩ lướt qua)</span></text><text for="L30">Khoảng thời gian, ở ngoài thời gian</text><text for="L31">Căn phòng trống, dịu dàng</text><text for="L32">Viên đường chậm rãi hòa tan trong dòng thời gian<span ttm:role="x-bg">(hòa tan trong dòng thời gian)</span></text><text for="L33">Tan đi và trở lại ngày mai, đầy những điều chưa biết</text></translation><translation xml:lang="zh-Hant"><text for="L1"><span begin="10.640" end="11.300">窗</span><span begin="11.300" end="11.670">外</span><span begin="11.670" end="12.020">的</span><span begin="12.250" end="12.860">春</span><span begin="12.860" end="13.820">天</span></text><text for="L2"><span begin="15.080" end="15.400">停</span><span begin="15.400" end="15.720">在</span><span begin="15.720" end="16.200">枝</span><span begin="16.310" end="16.680">頭</span><span begin="16.680" end="17.150">的</span><span begin="17.310" end="17.790">麻</span><span begin="17.790" end="18.570">雀</span></text><text for="L3"><span begin="20.060" end="20.360">初</span><span begin="20.360" end="20.650">次</span><span begin="20.650" end="21.240">察</span><span begin="21.240" end="21.710">覺</span><span begin="21.710" end="22.000">的</span><span begin="22.110" end="23.010">旋</span><span begin="23.010" end="23.320">律</span></text><text for="L4"><span begin="24.790" end="25.340">不</span><span begin="25.340" end="25.740">經</span><span begin="25.740" end="26.240">意</span><span begin="26.400" end="26.670">拂</span><span begin="26.670" end="27.020">過</span><span begin="27.510" end="27.980">心</span><span begin="27.980" end="28.550">尖</span></text><text for="L5"><span begin="30.760" end="31.320">點</span><span begin="31.320" end="31.650">一</span><span begin="31.650" end="32.090">支</span><span begin="32.090" end="32.830">香</span><span begin="32.830" end="34.270">籤</span></text><text for="L6"><span begin="35.120" end="35.330">放</span><span begin="35.330" end="35.700">下</span><span begin="35.700" end="36.270">繫</span><span begin="36.270" end="36.680">緊</span><span begin="36.680" end="37.020">的</span><span begin="37.310" end="37.790">髮</span><span begin="37.910" end="38.430">辮</span></text><text for="L7"><span begin="40.110" end="40.430">看</span><span begin="40.430" end="40.650">陌</span><span begin="40.650" end="41.330">生</span><span begin="41.330" end="41.690">柔</span><span begin="41.690" end="42.170">軟</span><span begin="42.330" end="42.850">光</span><span begin="42.850" end="43.460">線</span></text><text for="L8"><span begin="44.150" end="44.760">照</span><span begin="44.760" end="45.100">平</span><span begin="45.410" end="45.700">整</span><span begin="45.700" end="46.280">如</span><span begin="46.280" end="46.690">紙</span><span begin="46.690" end="47.090">的</span><span begin="47.570" end="47.910">晨</span><span begin="47.910" end="48.840">間</span></text><text for="L9"><span begin="49.430" end="50.020">追</span><span begin="50.020" end="50.400">雲</spa