			"translations": [
				{
					"language": "de",
					"text": "Sag irgendetwas, um mich in den Schlaf zu wiegen."
				},
				{
					"language": "en",
					"text": "Say anything to lull me to sleep"
				},
				{
					"language": "es",
					"text": "Palabras que llevan a un mundo de ilusiones"
				},
				{
					"language": "fr",
					"text": "Les mots m'emportent vers les bras Morphée"
				},
				{
					"language": "id",
					"text": "Bisikkan sesuatu dan antar aku ke alam mimpi"
				},
				{
					"language": "ja",
					"text": "言葉の微睡むに任せ"
				},
				{
					"language": "ko",
					"text": "말소리조차 천천히 잠에 들어"
				},
				{
					"language": "pt",
					"text": "Diga qualquer coisa para me fazer dormir"
				},
				{
					"language": "ru",
					"text": "Я усну под твои слова."
				},
				{
					"language": "th",
					"text": "พูดอะไรก็ได้เพื่อกล่อมฉันให้นอนหลับ"
