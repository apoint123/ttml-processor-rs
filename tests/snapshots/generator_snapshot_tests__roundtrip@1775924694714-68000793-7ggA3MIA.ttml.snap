					"end_time": 174100
				}
			],
			"translations": [
				{
					"language": "de",
					"text": "Geht es dir gut? Meine Gedanken flimmern."
				},
				{
					"language": "en",
					"text": "Are you alright? My thoughts flicker"
				},
				{
					"language": "es",
					"text": "¿Estás bien? Mis pensamientos han comenzado su disipación"
				},
				{
					"language": "fr",
					"text": "Tu vas bien ? Mes pensées vacillent"
				},
				{
					"language": "id",
					"text": "Apa kamu baik-baik saja? Pikiran pun datang dan pergi"
				},
				{
					"language": "ja",
					"text": "お元気ですか 浮かんでは消える"
				},
				{
					"language": "ko",
					"text": "넌 잘 지낼까 생각은 또 사라져가"
				},
				{
					"language": "pt",
					"text": "Você está bem? Meus pensamentos oscilam"
				},
				{
					"language": "ru",
					"text": "«Как ты?» — внезапный вопрос, словно вспышка."
				},
				{
					"language": "th",
					"text": "คุณสบายดีมั้ย? ความคิดของฉันกำลังสั่นคลอน"
				},
				{
					"language": "vi",
					"text": "Vẫn khỏe chứ? Suy nghĩ lướt qua"
				},
				{
					"language": "zh-Hant",
					"text": "你還好嗎 思緒明滅",
					"words": [
