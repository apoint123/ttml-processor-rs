			"translations": [
				{
					"language": "de",
					"text": "Ein hohles Weltbild, von mir allein erfasst,"
				},
				{
					"language": "en",
					"text": "An empty philosophy realized alone"
				},
				{
					"language": "es",
					"text": "En la filosofía vacía no hay colaboraciones"
				},
				{
					"language": "fr",
					"text": "Une philosophie vide réalisée par soi-même"
				},
				{
					"language": "id",
					"text": "Filosofi kosong yang disadari sendiri"
				},
				{
					"language": "ja",
					"text": "余白のある哲学にひとり頷き"
				},
				{
					"language": "ko",
					"text": "홀로 깨닫는 여백의 철학"
