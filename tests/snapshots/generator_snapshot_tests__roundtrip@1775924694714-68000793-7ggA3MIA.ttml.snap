			"text": "你还好吗 思绪明灭",
			"start_time": 169800,
			"end_time": 175680,
			"words": [
				{
					"text": "你",
					"start_time": 169800,
					"end_time": 170040
				},
				{
					"text": "还",
					"start_time": 170040,
					"end_time": 170310
				},
				{
					"text": "好",
					"start_time": 170310,
					"end_time": 170760
				},
				{
					"text": "吗",
					"start_time": 170760,
					"end_time": 171790,
					"ends_with_space": true
				},
