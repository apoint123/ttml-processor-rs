			"translations": [
				{
					"language": "de",
					"text": "Zeit, den Kopf in den Sand zu stecken und die Welt zu vergessen."
				},
				{
					"language": "en",
					"text": "Time to bury my head in the sand and forget the world"
				},
				{
					"language": "es",
					"text": "Tal vez debería esconderme y el mundo olvidar"
				},
				{
					"language": "fr",
					"text": "Tel un rocher, peut-être est-il temps d'oublier le monde"
				},
				{
					"language": "id",
					"text": "Mungkin saatnya mengubur kepalaku di pasir dan melupakan dunia"
				},
				{
					"language": "ja",
					"text": "石ころみたいに世界を忘れて"
				},
				{
					"language": "ko",
					"text": "바위처럼 세상을 잊고"
				},
				{
					"language": "pt",
					"text": "É hora de enterrar minha cabeça na areia e esquecer o mundo"
				},
				{
					"language": "ru",
					"text": "Может, просто спрятать голову в песок?"
				},
				{
					"language": "th",
					"text": "ถึงเวลาหลีกหนีทุกสิ่ง และลืมโลกนี้"
				},
				{
					"language": "vi",
					"text": "Có lẽ phải học cách quên đi thế giới như viên đá"
