			"translations": [
				{
					"language": "de",
					"text": "Ich will nichts verpassen, doch kann mich nicht voll und ganz darauf einzulassen."
				},
				{
					"language": "en",
					"text": "Unwilling to miss out, yet unable to fully commit"
				},
				{
					"language": "es",
					"text": "Ni la ausencia ni el compromiso son una opción"
				},
				{
					"language": "fr",
					"text": "Refuser l'absence, mais ne pas savoir s'engager"
				},
				{
					"language": "id",
					"text": "Tak ingin melewatinya, namun tak dapat berjanji"
				},
				{
					"language": "ja",
					"text": "失いたくないけど 追い求める覚悟もなくて"
				},
				{
					"language": "ko",
					"text": "빠지고 싶지도 완전히 미련을 둘 수도 없어"
				},
				{
					"language": "pt",
					"text": "Não quer perder nada, mas não consegue se comprometer totalmente"
				},
				{
					"language": "ru",
					"text": "Боюсь упустить, но не могу себя заставить."
